# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_REFERER=https://github.com/Leejames2305/LLM-Assisted-Path-Negotiation-on-Warehouse
OPENROUTER_TITLE=LLM Multi-Robot Navigation

# LLM Model Configuration
CENTRAL_LLM_MODEL=google/gemini-3.1-flash-lite-preview
AGENT_LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# OpenRouter Provider Order (comma-separated); Exp: openai,google-vertex,anthropic
OPENROUTER_PROVIDER_ORDER=google-vertex

# OpenRouter Reasoning Configuration; `Enabled` injects reasoning prompts, `Exclude` suppresses thinking prompts from responses
OPENROUTER_REASONING_ENABLED=true
OPENROUTER_REASONING_EXCLUDE=true
OPENROUTER_REASONING_EFFORT=medium

# Force injection of reasoning prompt no matter what
FORCE_REASONING_MODE=true

# Manual specification of reasoning models (comma-separated); Exp: deepseek-v3.2, gpt-5.2-pro
REASONING_MODELS=

# ================== LLM Negotiation Toggles ==================
# Disable all LLM-based conflict negotiation and run planner-only execution
DISABLE_LLM_NEGOTIATION=false

# ================== Path planner backend selection ==================
# Supported: astar, LNS2
PATH_PLANNER_MODE=LNS2

# LNS2 backend configuration
LNS2_MAX_ITERATIONS=16
LNS2_RANDOM_SEED=0
LNS2_PHASE1_RATIO=0.7
LNS2_MAX_INIT_RETRIES=3
LNS2_ADAPTIVE_STALL_ITERS=3
# Destroy strategies: randomwalk, adaptive
LNS2_DESTROY_STRATEGY=randomwalk
LNS2_DESTROY_RATIO=0.5
LNS2_DESTROY_RATIO_STEP=0.1
LNS2_RW_SAMPLES_PER_AGENT=4
LNS2_RW_MAX_EXPANSIONS=64
# Low-level backend: astar, sipp
LNS2_LOW_LEVEL_BACKEND=astar
LNS2_REPAIR_BACKEND=minicbs
LNS2_MINICBS_MAX_NODES=256

# ==================== TURN-BASED BENCHMARK ====================
# Number of agents (including no of boxes and targets)
BENCHMARK_NUM_AGENTS=8
# Number of benchmark rounds to run
BENCHMARK_NUM_ROUNDS=3
# Time limit per simulation round in seconds (0 = no limit)
BENCHMARK_TIME_LIMIT_SECONDS=300
# Random seed for reproducible position generation
BENCHMARK_SEED=42
# Enable spatial hints during benchmark (true/false)
BENCHMARK_SPATIAL_HINTS_ENABLED=true

# ==================== LIFELONG BENCHMARK ====================
LIFELONG_NUM_AGENTS=8
LIFELONG_NUM_ROUNDS=3
LIFELONG_DURATION_SECONDS=300
LIFELONG_SEED=42
LIFELONG_SPATIAL_HINTS_ENABLED=true

# ======================= LOGGING CONFIGURATION ========================
LOG_SIMULATION=true